  "keyFeatures": [
    "Modular architecture with independent scoped packages",
    "Comprehensive form components with validation support",
    "FormData-focused form components for file uploads",
    "Advanced UI components (Modal, Drawer, Toast, Carousel)",
    "Reusable React hooks for common patterns",
    "Theme management with multiple built-in themes",
    "TypeScript support with full type definitions",
    "Built with modern React patterns and Framer Motion animations"
  ],
  "publicApiSurface": [
    "@jeremiemeunier/core: Loader, CircleGauge",
    "@jeremiemeunier/carousel: Carousel",
    "@jeremiemeunier/cursor: CustomCursor",
    "@jeremiemeunier/drawer: DrawerProvider, useDrawer",
    "@jeremiemeunier/editorparser: EditorParser",
    "@jeremiemeunier/form: Input, Select, Checkbox, Radio, TextArea, DatePicker, FileInput, Autocomplete, TagInput, Password, TotpInput, DragAndDrop, Progress, Form, Group, Submit, Message",
    "@jeremiemeunier/x-form: XForm, XInput, XSelect, XCheckbox, XRadio, XTextArea, XSubmit",
    "@jeremiemeunier/hooks: useRefresh, useSeo",
    "@jeremiemeunier/modal: Modal (with Background, Body, Close, Header, MenuLeft, MenuRight, ModalCenter, Navigation, Pages)",
    "@jeremiemeunier/navigation: NavigationProvider, NavigationContext, Pagination",
    "@jeremiemeunier/popover: Popover (with Trigger, Content)",
    "@jeremiemeunier/theme: ThemeProvider, ThemeSelector, ThemeSwitch",
    "@jeremiemeunier/toast: ToastProvider, useToasts, Toast"
  ]
}
